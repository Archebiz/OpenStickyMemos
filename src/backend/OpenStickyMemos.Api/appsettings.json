{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=openstickymemos;Username=postgres"
  },
  "Jwt": {
    "Key": "DevOnly-ChangeMeInProduction-Min32Chars!",
    "Issuer": "OpenStickyMemos",
    "Audience": "OpenStickyMemos",
    "ExpiresInMinutes": 60,
    "RefreshExpiresInDays": 7
  },
  "App": {
    "BaseUrl": "http://localhost:5000"
  },
  "Web": {
    "BaseUrl": "http://localhost:4200"
  },
  "Email": {
    "Provider": "Log",
    "ApiKey": "",
    "FromEmail": "onboarding@resend.dev",
    "FromName": "OpenStickyMemos"
  },
  "OAuth": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/openstickymemos-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
