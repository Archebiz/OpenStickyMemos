<UserControl x:Class="OpenStickyMemos.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:OpenStickyMemos.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}">
    <Grid Background="#F0F2F5">
        <!-- Loading overlay -->
        <Border Background="White" Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Iniciando sesión..." FontSize="16" Foreground="#888"/>
            </StackPanel>
        </Border>

        <!-- WebView2 (hidden until login starts) -->
        <wv2:WebView2 x:Name="AuthWebView"
                      Visibility="{Binding ShowWebView, Converter={StaticResource BoolToVis}}"
                      Margin="0"/>

        <!-- Login buttons (hidden while WebView is showing) -->
        <Border Width="380" Height="Auto" Padding="32"
                Background="White" CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Visibility="{Binding ShowWebView, Converter={StaticResource InvertBoolToVis}}">
            <StackPanel>
                <TextBlock Text="📝" FontSize="48" TextAlignment="Center"/>
                <TextBlock Text="OpenStickyMemos" FontSize="22"
                           FontWeight="SemiBold" TextAlignment="Center"
                           Margin="0 8 0 4"/>
                <TextBlock Text="Notas colaborativas en tiempo real"
                           FontSize="13" Foreground="#888"
                           TextAlignment="Center" Margin="0 0 0 24"/>

                <Button Command="{Binding LoginWithGoogleCommand}"
                        Height="44" Margin="0 0 0 12"
                        Background="White" BorderBrush="#DDD"
                        BorderThickness="1" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="G" FontSize="18" FontWeight="Bold"
                                   Foreground="#4285F4" Margin="0 0 8 0"/>
                        <TextBlock Text="Iniciar sesión con Google"
                                   Foreground="#333" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding LoginWithMicrosoftCommand}"
                        Height="44" Margin="0 0 0 12"
                        Background="White" BorderBrush="#DDD"
                        BorderThickness="1" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="◆" FontSize="18" FontWeight="Bold"
                                   Foreground="#00A4EF" Margin="0 0 8 0"/>
                        <TextBlock Text="Iniciar sesión con Microsoft"
                                   Foreground="#333" FontSize="14"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C" FontSize="12"
                           TextAlignment="Center" Margin="0 8 0 0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
