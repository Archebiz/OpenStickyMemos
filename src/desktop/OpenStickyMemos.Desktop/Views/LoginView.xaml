<UserControl x:Class="OpenStickyMemos.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:OpenStickyMemos.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}">

    <UserControl.Resources>
        <!-- Animación de entrada -->
        <Storyboard x:Key="FadeInSlideUp">
            <DoubleAnimation Storyboard.TargetName="MainCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardTranslate"
                             Storyboard.TargetProperty="Y"
                             From="30" To="0"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- 🪟 Glass TextBox style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="CaretBrush" Value="#4A90D9"/>
            <Setter Property="BorderBrush" Value="#50B0C4DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="22,0,40,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="#F8FFFFFF"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#4A90D9" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#70FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Glass PasswordBox style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="CaretBrush" Value="#4A90D9"/>
            <Setter Property="BorderBrush" Value="#50B0C4DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="22,0,52,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="#F8FFFFFF"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#4A90D9" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#70FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Glass CheckBox -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBorder" Width="18" Height="18"
                                    CornerRadius="5" BorderBrush="#60B0C4DE"
                                    BorderThickness="1.5" Background="#E8FFFFFF"
                                    Margin="0,0,8,0">
                                <Path x:Name="checkMark" Data="M 2 9 L 7 14 L 16 3"
                                      Stroke="#4A90D9" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#4A90D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Glass OAuth button -->
        <Style x:Key="OAuthButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#50B0C4DE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F8FFFFFF"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#80FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Glass inline icon button -->
        <Style x:Key="InlineIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#00000010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Submit button (pastel gradient) -->
        <Style x:Key="SubmitButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4A90D9" Offset="0"/>
                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#4A90D9" BlurRadius="16" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <!-- Loading overlay -->
        <Border Background="#F0E8FE"
                Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Iniciando sesión..."
                        FontSize="16" Foreground="#4A5568"/>
            </StackPanel>
        </Border>

        <!-- WebView para OAuth -->
        <wv2:WebView2 x:Name="AuthWebView"
                      Visibility="{Binding ShowWebView, Converter={StaticResource BoolToVis}}"
                      Margin="0"/>

        <!-- Fondo con gradiente pastel -->
        <Border Visibility="{Binding ShowWebView, Converter={StaticResource InvertBoolToVis}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#DEE8FF"/>
                    <GradientStop Offset="0.4" Color="#FFE8F0"/>
                    <GradientStop Offset="0.7" Color="#F0E8FF"/>
                    <GradientStop Offset="1" Color="#E8FFE8"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Círculos decorativos pastel -->
                <Ellipse Width="350" Height="350"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-120,-100,0,0" Opacity="0.12">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFB3BA" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Ellipse Width="280" Height="280"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-80,-80" Opacity="0.12">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#BAE1FF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Ellipse Width="200" Height="200"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Margin="160,120,0,0" Opacity="0.08">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#E8BAFF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Card principal glassmorphism pastel -->
                <Border x:Name="MainCard"
                        Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="20"
                        Opacity="0"
                        Padding="40,28,40,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                            <GradientStop Offset="0" Color="#F5FFFFFF"/>
                            <GradientStop Offset="1" Color="#E8FFFFFF"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#70FFFFFF"/>
                            <GradientStop Offset="1" Color="#40FFFFFF"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.12" Color="#000"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="CardTranslate" Y="30"/>
                    </Border.RenderTransform>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Settings + Versión + Cerrar -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="&#x2699;&#xFE0F;"
                                    FontSize="14" Style="{StaticResource InlineIconButton}"
                                    Padding="4" Margin="-4,-4,0,0"
                                    Command="{Binding OpenSettingsCommand}"/>
                            <TextBlock Grid.Column="1" Text="{Binding VersionText}"
                                       FontSize="10" Foreground="#A0AEC0"
                                       VerticalAlignment="Center" Margin="4,6,0,0"/>
                            <Button Grid.Column="2" x:Name="btnCerrar"
                                    HorizontalAlignment="Right" Width="28" Height="28"
                                    Content="&#x2715;" FontSize="12"
                                    Foreground="#A0AEC0" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Style="{StaticResource InlineIconButton}"
                                    Command="{Binding CloseAppCommand}"
                                    Margin="0,-4,-4,0"/>
                        </Grid>

                        <!-- Logo -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Image Source="pack://application:,,,/Resources/Images/logo-nbg.png"
                                   Width="200" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Campo Nombre (solo en registro) -->
                        <Grid Grid.Row="3"
                              Visibility="{Binding IsLoginMode, Converter={StaticResource InvertBoolToVis}}">
                            <TextBox x:Name="TxtNombre" Style="{StaticResource ModernTextBox}"
                                     Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="TxtClave_KeyDown"/>
                            <TextBlock Text="&#x1F464;" FontSize="14" Foreground="#A0AEC0"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Margin="14,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="PlaceholderNombre" Text="Nombre completo"
                                       Foreground="#A0AEC0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Margin="44,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=TxtNombre}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Campo Email -->
                        <Grid Grid.Row="5">
                            <TextBox x:Name="TxtEmail" Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="TxtClave_KeyDown"/>
                            <TextBlock Text="&#x2709;" FontSize="14" Foreground="#A0AEC0"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Margin="14,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="PlaceholderEmail" Text="Correo electrónico"
                                       Foreground="#A0AEC0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Margin="44,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=TxtEmail}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Campo Contraseña -->
                        <Grid Grid.Row="7">
                            <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}"
                                         KeyDown="TxtClave_KeyDown" PasswordChanged="TxtClave_PasswordChanged"/>
                            <TextBox x:Name="txtClaveVisible" Style="{StaticResource ModernTextBox}"
                                     Padding="44,0,52,0" Visibility="Collapsed" KeyDown="TxtClave_KeyDown"/>
                            <TextBlock Text="&#x1F511;" FontSize="14" Foreground="#A0AEC0"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Margin="14,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="PlaceholderPassword" Text="Contraseña"
                                       Foreground="#A0AEC0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Margin="44,0,0,0" IsHitTestVisible="False"/>
                            <Button x:Name="btnTogglePassword"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,10,0" Width="32" Height="32"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Style="{StaticResource InlineIconButton}"
                                    Click="BtnTogglePassword_Click">
                                <TextBlock x:Name="ToggleIcon" Text="&#x1F441;"
                                           FontSize="16" Foreground="#A0AEC0"/>
                            </Button>
                        </Grid>

                        <!-- Recordar contraseña -->
                        <CheckBox Grid.Row="9" x:Name="chkRecordarPassword"
                                  Content="Recordar contraseña"
                                  Style="{StaticResource ModernCheckBox}"
                                  IsChecked="{Binding RememberPassword}"/>

                        <!-- Olvidé mi contraseña -->
                        <TextBlock Grid.Row="10" TextAlignment="Right" Margin="0,4,0,0" FontSize="11">
                            <Hyperlink Command="{Binding OpenForgotPasswordCommand}" Foreground="#A0AEC0">
                                ¿Olvidaste tu contraseña?
                            </Hyperlink>
                        </TextBlock>

                        <!-- Botón Ingresar -->
                        <Button Grid.Row="11" x:Name="BtnSubmit"
                                Style="{StaticResource SubmitButtonStyle}"
                                Command="{Binding LoginWithEmailCommand}">
                            <Grid>
                                <StackPanel x:Name="pnlNormal" Orientation="Horizontal"
                                            Visibility="{Binding IsLoading, Converter={StaticResource InvertBoolToVis}}">
                                    <TextBlock Text="{Binding IsLoginMode, Converter={StaticResource LoginRegisterText}}"
                                               Foreground="White" FontFamily="Segoe UI"
                                               FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="  →" Foreground="White" FontSize="15"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel x:Name="pnlLoading" Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Iniciando sesión..." Foreground="White"
                                               FontFamily="Segoe UI" FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Link login/register -->
                        <TextBlock Grid.Row="13" Margin="0,6,0,0" TextAlignment="Center" FontSize="12">
                            <Hyperlink Command="{Binding ToggleModeCommand}">
                                <TextBlock Text="{Binding IsLoginMode, Converter={StaticResource ToggleLoginText}}"
                                           Foreground="#718096"/>
                            </Hyperlink>
                        </TextBlock>

                        <!-- Error message -->
                        <TextBlock Grid.Row="14" Text="{Binding ErrorMessage}"
                                   Foreground="#E53E3E" FontSize="11" TextAlignment="Center"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVis}}"/>

                        <!-- Divisor -->
                        <Border Grid.Row="15" BorderBrush="#30B0C4DE" BorderThickness="0 1 0 0"
                                Margin="0,14,0,0"/>

                        <!-- Sección OAuth -->
                        <StackPanel Grid.Row="16" Margin="0,14,0,0">
                            <TextBlock Text="o continúa con" FontSize="11"
                                       Foreground="#A0AEC0" TextAlignment="Center" Margin="0,0,0,10"/>

                            <Button Command="{Binding LoginWithGoogleCommand}"
                                    Margin="0,0,0,8" Style="{StaticResource OAuthButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Google Logo (SVG path) -->
                                    <Canvas Width="20" Height="20" Margin="0,0,8,0">
                                        <Path Data="M19.6,10.23c0-.68-.06-1.36-.18-2.02H10v3.82h5.38a4.55,4.55,0,0,1-1.97,3l0,.01,2.86,2.22.1,.09A9.66,9.66,0,0,0,19.6,10.23Z"
                                              Fill="#4285F4"/>
                                        <Path Data="M10,20a9.6,9.6,0,0,0,6.56-2.42l-3.13-2.43A5.73,5.73,0,0,1,10,15.77a5.7,5.7,0,0,1-5.37-3.95l0,0-2.92,2.26-.08,.09A10,10,0,0,0,10,20Z"
                                              Fill="#34A853"/>
                                        <Path Data="M4.63,11.82A6.06,6.06,0,0,1,4.32,10a6.09,6.09,0,0,1,.28-1.82l0-.07L1.62,5.78l-.07-.05A9.94,9.94,0,0,0,0,10a9.94,9.94,0,0,0,1.55,4.27l3.06-2.37Z"
                                              Fill="#FBBC05"/>
                                        <Path Data="M10,4.23a5.44,5.44,0,0,1,3.86,1.5l2.82-2.76A9.57,9.57,0,0,0,10,0,10,10,0,0,0,1.55,5.73l2.97,2.3A5.7,5.7,0,0,1,10,4.23Z"
                                              Fill="#EA4335"/>
                                    </Canvas>
                                    <TextBlock Text="Continuar con Google" Foreground="#4A5568"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding LoginWithMicrosoftCommand}"
                                    Style="{StaticResource OAuthButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Microsoft Logo (4 colored squares) -->
                                    <Grid Width="20" Height="20" Margin="0,0,8,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="10*"/>
                                            <RowDefinition Height="10*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10*"/>
                                            <ColumnDefinition Width="10*"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Row="0" Grid.Column="0" Fill="#F25022" Margin="0.5"/>
                                        <Rectangle Grid.Row="0" Grid.Column="1" Fill="#7FBA00" Margin="0.5"/>
                                        <Rectangle Grid.Row="1" Grid.Column="0" Fill="#00A4EF" Margin="0.5"/>
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="0.5"/>
                                    </Grid>
                                    <TextBlock Text="Continuar con Microsoft" Foreground="#4A5568"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInSlideUp}"/>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>