<UserControl x:Class="OpenStickyMemos.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:OpenStickyMemos.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}">
    <Grid Background="Transparent">
        <!-- Loading overlay -->
        <Border Background="White" Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Iniciando sesion..." FontSize="16" Foreground="#888"/>
            </StackPanel>
        </Border>

        <!-- WebView para OAuth -->
        <wv2:WebView2 x:Name="AuthWebView"
                      Visibility="{Binding ShowWebView, Converter={StaticResource BoolToVis}}"
                      Margin="0"/>

        <!-- Card de login -->
        <Border Width="380" Height="Auto" Padding="28" Background="White" CornerRadius="16"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Visibility="{Binding ShowWebView, Converter={StaticResource InvertBoolToVis}}"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <!-- Logo y título -->
                <TextBlock Text="📝" FontSize="40" TextAlignment="Center"/>
                <TextBlock Text="OpenStickyMemos" FontSize="20" FontWeight="SemiBold"
                           TextAlignment="Center" Margin="0 4 0 2"/>
                <TextBlock Text="Notas colaborativas en tiempo real" FontSize="12"
                           Foreground="#999" TextAlignment="Center" Margin="0 0 0 16"/>

                <!-- Email -->
                <TextBlock Text="Correo electrónico" FontSize="11" FontWeight="SemiBold" Foreground="#666" Margin="0 0 0 4"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="10 9" Margin="0 0 0 12" BorderBrush="#DDD" BorderThickness="1"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña" FontSize="11" FontWeight="SemiBold" Foreground="#666" Margin="0 0 0 4"/>
                <Grid Margin="0 0 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="PasswordBox" Grid.Column="0"
                                 FontSize="13" Padding="10 9" BorderBrush="#DDD" BorderThickness="1"/>
                    <Button Grid.Column="1" Width="36" Height="36"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" FontSize="16"
                            Click="TogglePasswordVisibility">👁️</Button>
                </Grid>

                <!-- DisplayName (solo registro) -->
                <StackPanel Visibility="{Binding IsLoginMode, Converter={StaticResource InvertBoolToVis}}">
                    <TextBlock Text="Nombre (opcional)" FontSize="11" FontWeight="SemiBold" Foreground="#666" Margin="0 0 0 4"/>
                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Padding="10 9" Margin="0 0 0 12" BorderBrush="#DDD" BorderThickness="1"/>
                </StackPanel>

                <!-- Botón principal -->
                <Button Command="{Binding LoginWithEmailCommand}" Height="38"
                        Background="#667eea" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0 0 0 4" FontSize="14" FontWeight="SemiBold">
                    <TextBlock Text="{Binding IsLoginMode, Converter={StaticResource LoginRegisterText}}"/>
                </Button>

                <!-- Link login/register -->
                <TextBlock Margin="0 6 0 0" TextAlignment="Center" FontSize="12">
                    <Hyperlink Command="{Binding ToggleModeCommand}">
                        <TextBlock Text="{Binding IsLoginMode, Converter={StaticResource ToggleLoginText}}"/>
                    </Hyperlink>
                </TextBlock>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E74C3C" FontSize="11"
                           TextAlignment="Center" Margin="0 6 0 0"/>

                <!-- Divisor -->
                <Border BorderBrush="#EEE" BorderThickness="0 1 0 0" Margin="0 14"/>

                <TextBlock Text="o continúa con" FontSize="11" Foreground="#AAA"
                           TextAlignment="Center" Margin="0 0 0 10"/>

                <!-- Google -->
                <Button Command="{Binding LoginWithGoogleCommand}" Height="42" Margin="0 0 0 8"
                        Background="White" BorderBrush="#DADCE0" BorderThickness="1" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="G" FontSize="20" FontWeight="Bold" Foreground="#4285F4"
                                   Margin="0 0 8 0" FontFamily="Georgia"/>
                        <TextBlock Text="Continuar con Google" Foreground="#333" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Microsoft -->
                <Button Command="{Binding LoginWithMicrosoftCommand}" Height="42"
                        Background="White" BorderBrush="#DADCE0" BorderThickness="1" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Rectangle Width="20" Height="20" Margin="0 0 8 0" Fill="#00A4EF" RadiusX="4" RadiusY="4"/>
                        <TextBlock Text="Continuar con Microsoft" Foreground="#333" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Versión y settings -->
                <Border BorderBrush="#EEE" BorderThickness="0 1 0 0" Margin="0 14 0 8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="v1.0.2" FontSize="10" Foreground="#BBB"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="⚙️" FontSize="14"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="4"
                            ToolTip="Configuración del servidor"
                            Command="{Binding OpenSettingsCommand}"/>
                    <Button Grid.Column="2" Content="✕" FontSize="12" Width="28" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Foreground="#999"
                            Command="{Binding CloseAppCommand}"
                            ToolTip="Cerrar"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>