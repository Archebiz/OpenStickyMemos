<UserControl x:Class="OpenStickyMemos.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:OpenStickyMemos.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}">
    <Grid Background="#F0F2F5">
        <Border Background="White" Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Iniciando sesion..." FontSize="16" Foreground="#888"/>
            </StackPanel>
        </Border>
        <wv2:WebView2 x:Name="AuthWebView"
                      Visibility="{Binding ShowWebView, Converter={StaticResource BoolToVis}}"
                      Margin="0"/>
        <Border Width="380" Height="Auto" Padding="32" Background="White" CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Visibility="{Binding ShowWebView, Converter={StaticResource InvertBoolToVis}}">
            <StackPanel>
                <TextBlock Text=":memo:" FontSize="48" TextAlignment="Center"/>
                <TextBlock Text="OpenStickyMemos" FontSize="22" FontWeight="SemiBold"
                           TextAlignment="Center" Margin="0 8 0 4"/>
                <TextBlock Text="Notas colaborativas en tiempo real" FontSize="13"
                           Foreground="#888" TextAlignment="Center" Margin="0 0 0 16"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10" Margin="0 0 0 8" BorderBrush="#DDD" BorderThickness="1"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10" Margin="0 0 0 8" BorderBrush="#DDD" BorderThickness="1"/>
                <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10" Margin="0 0 0 8" BorderBrush="#DDD" BorderThickness="1"
                         Visibility="{Binding IsLoginMode, Converter={StaticResource InvertBoolToVis}}"/>
                <Button Command="{Binding LoginWithEmailCommand}" Height="40"
                        Background="#667eea" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0 0 0 4">
                    <TextBlock Text="{Binding IsLoginMode, Converter={StaticResource LoginRegisterText}}"/>
                </Button>
                <TextBlock Margin="0 0 12 0" TextAlignment="Center">
                    <Hyperlink Command="{Binding ToggleModeCommand}">
                        <TextBlock Text="{Binding IsLoginMode, Converter={StaticResource ToggleLoginText}}"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E74C3C" FontSize="12"
                           TextAlignment="Center" Margin="0 0 0 12"/>
                <Border BorderBrush="#EEE" BorderThickness="0 1 0 0" Margin="0 0 0 12"/>
                <TextBlock Text="o continua con" FontSize="12" Foreground="#AAA"
                           TextAlignment="Center" Margin="0 0 0 8"/>
                <Button Command="{Binding LoginWithGoogleCommand}" Height="44" Margin="0 0 0 8"
                        Background="White" BorderBrush="#DDD" BorderThickness="1" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="G" FontSize="18" FontWeight="Bold" Foreground="#4285F4" Margin="0 0 8 0"/>
                        <TextBlock Text="Google" Foreground="#333" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding LoginWithMicrosoftCommand}" Height="44"
                        Background="White" BorderBrush="#DDD" BorderThickness="1" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="M" FontSize="18" FontWeight="Bold" Foreground="#00A4EF" Margin="0 0 8 0"/>
                        <TextBlock Text="Microsoft" Foreground="#333" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>