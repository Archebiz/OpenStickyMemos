<Window x:Class="OpenStickyMemos.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración"
        Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Estilo TextBox settings -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="CaretBrush" Value="#06B6D4"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#06B6D4"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#06B6D4" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botón primario -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0EA5E9" Offset="0"/>
                                    <GradientStop Color="#2563EB" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botón secundario -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Fondo con gradiente -->
    <Border CornerRadius="16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1E3A5F" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="28,20,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Configuración" Foreground="#F1F5F9"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Configuración del servidor y OAuth"
                               Foreground="#64748B" FontFamily="Segoe UI" FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="&#x2715;" FontSize="14"
                        Width="28" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#94A3B8" Cursor="Hand"
                        Click="BtnCancelar_Click"
                        Margin="0,-4,-4,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#FFFFFF15"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Sección: Servidor -->
                    <TextBlock Text="SERVIDOR API" Foreground="#06B6D4"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="URL del servidor" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtApiUrl" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Text="URL del frontend web" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtWebUrl" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,16"/>

                    <!-- Sección: Google OAuth -->
                    <TextBlock Text="GOOGLE OAUTH" Foreground="#06B6D4"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Client ID" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtGoogleClientId" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Text="Redirect URI" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtGoogleRedirectUri" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,16"/>

                    <!-- Sección: Microsoft OAuth -->
                    <TextBlock Text="MICROSOFT OAUTH" Foreground="#06B6D4"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Client ID" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtMicrosoftClientId" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Text="Tenant ID" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtMicrosoftTenantId" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Text="Redirect URI" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtMicrosoftRedirectUri" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Botones de acción -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="lblMensaje"
                           Foreground="#22C55E" FontSize="11" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <Button Grid.Column="2" Content="Cancelar"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="100" Click="BtnCancelar_Click"/>
                <Button Grid.Column="3" Content="Guardar"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100" Click="BtnGuardar_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>