<Window x:Class="OpenStickyMemos.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración"
        Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 🪟 Glass TextBox for settings -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="CaretBrush" Value="#4A90D9"/>
            <Setter Property="BorderBrush" Value="#50B0C4DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="#F8FFFFFF"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#4A90D9" BlurRadius="8" ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#70FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Glass primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4A90D9" Offset="0"/>
                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Glass secondary button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Background" Value="#F0FFFFFF"/>
            <Setter Property="BorderBrush" Value="#50B0C4DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F8FFFFFF"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#80FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Glass close button -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#00000010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🪟 Section label style -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4A90D9"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- 🪟 Field label style -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <!-- Glassmorphism background -->
    <Border CornerRadius="18">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#E8F0FE"/>
                <GradientStop Offset="0.5" Color="#F0E8FE"/>
                <GradientStop Offset="1" Color="#E0F7FA"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.18"/>
        </Border.Effect>

        <Grid Margin="28,20,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Configuración" Foreground="#2D3748"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Configuración del servidor y OAuth"
                               Foreground="#718096" FontFamily="Segoe UI" FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="&#x2715;" FontSize="14"
                        Width="28" Height="28"
                        Foreground="#A0AEC0" Cursor="Hand"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="BtnCancelar_Click"
                        Margin="0,-4,-4,0"/>
            </Grid>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Glass card: Servidor -->
                    <Border CornerRadius="12" Padding="14"
                            Background="#F5FFFFFF" BorderBrush="#40FFFFFF" BorderThickness="1"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="SERVIDOR API" Style="{StaticResource SectionLabelStyle}"/>
                            <TextBlock Text="URL del servidor" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtApiUrl" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="URL del frontend web" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtWebUrl" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Glass card: Google OAuth -->
                    <Border CornerRadius="12" Padding="14"
                            Background="#F5FFFFFF" BorderBrush="#40FFFFFF" BorderThickness="1"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="G" FontSize="16" FontWeight="Bold" Foreground="#4285F4"
                                           FontFamily="Georgia" Margin="0,0,6,0"/>
                                <TextBlock Text="GOOGLE OAUTH" Style="{StaticResource SectionLabelStyle}"/>
                            </StackPanel>
                            <TextBlock Text="Client ID" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtGoogleClientId" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Redirect URI" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtGoogleRedirectUri" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Glass card: Microsoft OAuth -->
                    <Border CornerRadius="12" Padding="14"
                            Background="#F5FFFFFF" BorderBrush="#40FFFFFF" BorderThickness="1"
                            Margin="0,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Rectangle Width="16" Height="16" Fill="#00A4EF" RadiusX="3" RadiusY="3"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="MICROSOFT OAUTH" Style="{StaticResource SectionLabelStyle}"/>
                            </StackPanel>
                            <TextBlock Text="Client ID" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtMicrosoftClientId" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Tenant ID" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtMicrosoftTenantId" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Redirect URI" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtMicrosoftRedirectUri" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Botones de acción -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="lblMensaje"
                           Foreground="#38A169" FontSize="11" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <Button Grid.Column="2" Content="Cancelar"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="100" Click="BtnCancelar_Click"/>
                <Button Grid.Column="4" Content="Guardar"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100" Click="BtnGuardar_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>