<UserControl x:Class="OpenStickyMemos.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OpenStickyMemos.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}">
    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20 16">
            <TextBlock Text="Mis Proyectos" FontSize="20"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Loading -->
        <TextBlock Grid.Row="1" Text="Cargando proyectos..."
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#888"/>

        <!-- Error -->
        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVis}}"
                   Foreground="#E74C3C" HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasProjects, Converter={StaticResource InvertBoolToVis}}">
            <TextBlock Text="📋" FontSize="48" TextAlignment="Center"/>
            <TextBlock Text="No tienes proyectos aún" FontSize="16"
                       Foreground="#888" TextAlignment="Center"
                       Margin="0 8 0 0"/>
        </StackPanel>

        <!-- Project list -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Projects}"
                  Margin="20"
                  Visibility="{Binding HasProjects, Converter={StaticResource BoolToVis}}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16" Margin="0 0 0 8"
                            Background="White" CornerRadius="8"
                            BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontSize="15"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Description}"
                                       FontSize="12" Foreground="#888"
                                       Margin="0 4 0 0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
