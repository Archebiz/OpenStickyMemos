<Window x:Class="OpenStickyMemos.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OpenStickyMemos.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="OpenStickyMemos" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#667eea" Padding="12 8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="OpenStickyMemos"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding UserDisplayName}"
                               Foreground="White" VerticalAlignment="Center"
                               Margin="0 0 12 0"/>
                    <Button Content="Cerrar sesión" Command="{Binding LogoutCommand}"
                            Background="Transparent" BorderBrush="White"
                            Foreground="White" BorderThickness="1"
                            Padding="8 4" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Row="1" x:Name="MainContentArea"/>
    </Grid>
</Window>
