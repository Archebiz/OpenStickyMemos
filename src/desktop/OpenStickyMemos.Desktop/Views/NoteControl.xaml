<UserControl x:Class="OpenStickyMemos.Desktop.Views.NoteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             MinWidth="120" MinHeight="80">
    <Border x:Name="NoteBorder" CornerRadius="8"
            BorderBrush="#D0D0D0" BorderThickness="1"
            Padding="12" RenderTransformOrigin="0.5,0.5"
            Background="#FFE066">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Opacity="0.2" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Pin indicator & actions -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0 0 0 4">
                <TextBlock x:Name="PinIndicator" Text="📌" FontSize="12"
                           Visibility="Collapsed" Margin="0 0 4 0"/>
                <Button x:Name="DeleteButton" Content="×" FontSize="14"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888" Cursor="Hand" Padding="2"
                        Click="DeleteButton_Click"/>
            </StackPanel>

            <!-- Title -->
            <TextBox x:Name="TitleBox" Grid.Row="1"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" FontWeight="SemiBold"
                     Background="Transparent" BorderThickness="0"
                     Margin="0 0 0 4" TextWrapping="Wrap"
                     AcceptsReturn="False" Foreground="#333"
                     GotFocus="TitleBox_GotFocus" LostFocus="TitleBox_LostFocus"/>

            <!-- Content -->
            <TextBox x:Name="ContentBox" Grid.Row="2"
                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="12" Background="Transparent"
                     BorderThickness="0" TextWrapping="Wrap"
                     AcceptsReturn="True" Foreground="#555"
                     MinHeight="40"
                     GotFocus="ContentBox_GotFocus" LostFocus="ContentBox_LostFocus"/>

            <!-- Resize handle (bottom-right) -->
            <Thumb x:Name="ResizeThumb" Grid.Row="2"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="12" Height="12" Cursor="SizeNWSE"
                   DragDelta="ResizeThumb_DragDelta">
                <Thumb.Template>
                    <ControlTemplate>
                        <Path Data="M0,12 L12,0 L12,12 Z"
                              Fill="#C0C0C0" Opacity="0.5"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>
