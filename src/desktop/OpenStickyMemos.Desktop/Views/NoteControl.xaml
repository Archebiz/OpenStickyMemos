<UserControl x:Class="OpenStickyMemos.Desktop.Views.NoteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             MinWidth="120" MinHeight="80">
    <Border x:Name="NoteBorder" CornerRadius="8"
            BorderBrush="#D0D0D0" BorderThickness="1"
            Padding="12" RenderTransformOrigin="0.5,0.5"
            Background="#FFE066">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Opacity="0.2" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar: z-order + pin + color + delete -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0 0 0 4">
                <Button x:Name="BringFrontButton" Content="⬆" FontSize="10"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888" Cursor="Hand" Padding="2 0"
                        ToolTip="Traer al frente" Click="BringFrontButton_Click"/>
                <Button x:Name="SendBackButton" Content="⬇" FontSize="10"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888" Cursor="Hand" Padding="2 0"
                        ToolTip="Enviar al fondo" Click="SendBackButton_Click"/>
                <Button x:Name="PinButton" Content="📌" FontSize="12"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888" Cursor="Hand" Padding="2"
                        ToolTip="Fijar nota" Click="PinButton_Click"/>
                <Button x:Name="ColorButton" Content="🎨" FontSize="12"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888" Cursor="Hand" Padding="2"
                        ToolTip="Cambiar color" Click="ColorButton_Click"/>
                <Button x:Name="DeleteButton" Content="×" FontSize="14"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888" Cursor="Hand" Padding="2"
                        ToolTip="Eliminar" Click="DeleteButton_Click"/>
            </StackPanel>

            <!-- === VIEW MODE (doble click para editar) === -->
            <Grid Grid.Row="1" x:Name="ViewPanel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="ViewTitle" Grid.Row="0"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#333" TextWrapping="Wrap"
                           Margin="0 0 0 4"/>
                <TextBlock x:Name="ViewContent" Grid.Row="1"
                           FontSize="12" Foreground="#555"
                           TextWrapping="Wrap" Margin="0 0 0 4"/>
            </Grid>

            <!-- === EDIT MODE === -->
            <Grid Grid.Row="1" x:Name="EditPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="TitleBox" Grid.Row="0"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" FontWeight="SemiBold"
                         Background="#FFFFFF80" BorderThickness="1"
                         BorderBrush="#CCC" Margin="0 0 0 4"
                         Padding="4" TextWrapping="Wrap"
                         AcceptsReturn="False" Foreground="#333"
                         LostFocus="TitleBox_LostFocus"/>
                <TextBox x:Name="ContentBox" Grid.Row="1"
                         Text="{Binding NoteContent, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" Background="#FFFFFF80"
                         BorderThickness="1" BorderBrush="#CCC"
                         Padding="4" TextWrapping="Wrap"
                         AcceptsReturn="True" Foreground="#555"
                         MinHeight="40"
                         LostFocus="ContentBox_LostFocus"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0 4 0 0">
                    <Button x:Name="SaveButton" Content="✓ Guardar"
                            FontSize="11" Padding="6 2"
                            Background="#667eea" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Resize handle (bottom-right) -->
            <Thumb x:Name="ResizeThumb" Grid.Row="2"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="12" Height="12" Cursor="SizeNWSE"
                   DragDelta="ResizeThumb_DragDelta">
                <Thumb.Template>
                    <ControlTemplate>
                        <Path Data="M0,12 L12,0 L12,12 Z"
                              Fill="#C0C0C0" Opacity="0.5"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>
